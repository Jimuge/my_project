# ============================================================
# AI 热点分析 Workflow — 环境变量配置文件
# ============================================================
# 使用方法：
#   1. 把这个文件(.env.example)复制一份，重命名为 .env
#   2. 在 .env 中填入你真实的 API Key 和邮箱信息
#   3. .env 文件默认被 .gitignore 忽略，不会提交到 Git
#
# 如何获取这些 Key？
#   DeepSeek：     https://platform.deepseek.com/api_keys
#   SiliconFlow：  https://cloud.siliconflow.cn (控制台 → API Key)
#   163邮箱授权码：设置 → POP3/SMTP → 开启服务并生成授权码
# ============================================================

# ============================================================
# DeepSeek API 配置（必填）
# ============================================================
# DeepSeek 的 API 密钥，用来调用 AI 分析热点和生成标题
DEEPSEEK_API_KEY=你的DeepSeek_API_Key

# DeepSeek API 地址（一般不用改）
DEEPSEEK_BASE_URL=https://api.deepseek.com

# DeepSeek 模型名称（默认 deepseek-chat）
DEEPSEEK_MODEL=deepseek-chat

# ============================================================
# SiliconFlow API 配置（生成配图，可选）
# ============================================================
# SiliconFlow 的 API 密钥，用来生成 AI 配图
# 如果不填，可以加 --skip-image 参数跳过配图生成
SILICONFLOW_API_KEY=你的SiliconFlow_API_Key

# SiliconFlow API 地址（一般不用改）
SILICONFLOW_BASE_URL=https://api.siliconflow.cn/v1

# 图片生成模型（默认使用 FLUX.1-dev 模型）
SILICONFLOW_IMAGE_MODEL=Kwai-Kolors/Kolors

# 生成图片的尺寸
IMAGE_SIZE=1024x1024

# ============================================================
# 邮箱配置（必填）
# ============================================================
# SMTP 服务器地址（QQ: smtp.qq.com, 163: smtp.163.com, Gmail: smtp.gmail.com）
SMTP_SERVER=smtp.163.com

# SMTP 端口（SSL 用 465，TLS 用 587）
SMTP_PORT=465

# 发件人邮箱地址
SMTP_USER=你的邮箱@163.com

# SMTP 授权码（不是邮箱登录密码！163邮箱需在设置中生成授权码）
SMTP_PASSWORD=你的SMTP授权码

# 收件人邮箱地址
TO_EMAIL=收件人邮箱@163.com

# ============================================================
# 其他配置（可选）
# ============================================================
# 每次抓取多少条热搜进行分析（建议 10-20 条）
HOT_TOP_COUNT=15
