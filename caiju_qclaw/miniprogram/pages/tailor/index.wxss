/* 量体师工作台 */
.page {
  background-color: #F5F5F5;
  min-height: 100vh;
  padding-bottom: 180rpx;
}

.header {
  background: linear-gradient(135deg, #1B2A4A 0%, #2D4270 100%);
  padding: 40rpx 32rpx 60rpx;
  color: #FFFFFF;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.greeting {
  font-size: 36rpx;
  font-weight: 600;
}

.header-right {
  display: flex;
  align-items: center;
}

.switch-label {
  font-size: 24rpx;
  margin-left: 8rpx;
  opacity: 0.9;
}

.accept-switch {
  transform: scale(0.8);
}

/* 大数字卡片 */
.main-stat {
  margin: -40rpx 32rpx 24rpx;
  background: #FFFFFF;
  border-radius: 16rpx;
  padding: 40rpx;
  display: flex;
  align-items: baseline;
  box-shadow: 0 4rpx 16rpx rgba(27, 42, 74, 0.08);
}

.stat-label {
  font-size: 28rpx;
  color: #666666;
  margin-right: 16rpx;
}

.stat-number {
  font-size: 72rpx;
  font-weight: 700;
  color: #1B2A4A;
  line-height: 1;
}

.stat-unit {
  font-size: 28rpx;
  color: #999999;
  margin-left: 8rpx;
}

/* 新订单提醒 */
.new-order-tip {
  margin: 0 32rpx 24rpx;
  background: #FFF8F0;
  border: 2rpx solid #C9A96E;
  border-radius: 16rpx;
  padding: 24rpx 32rpx;
  display: flex;
  align-items: center;
  font-size: 28rpx;
  color: #C9A96E;
  font-weight: 500;
}

.tip-icon {
  width: 36rpx;
  height: 36rpx;
  margin-right: 12rpx;
}

.tip-arrow {
  margin-left: auto;
  font-size: 36rpx;
}

/* 数据概览 */
.overview-row {
  display: flex;
  margin: 0 32rpx 24rpx;
  gap: 16rpx;
}

.overview-item {
  flex: 1;
  background: #FFFFFF;
  border-radius: 16rpx;
  padding: 28rpx 20rpx;
  text-align: center;
  box-shadow: 0 4rpx 16rpx rgba(27, 42, 74, 0.08);
}

.overview-value {
  font-size: 40rpx;
  font-weight: 700;
  color: #1B2A4A;
}

.overview-label {
  font-size: 22rpx;
  color: #999999;
  margin-top: 8rpx;
}

/* 近期订单 */
.section {
  margin: 0 32rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1B2A4A;
}

.section-more {
  font-size: 26rpx;
  color: #C9A96E;
}

.order-item {
  margin-bottom: 16rpx;
}

/* 底部快捷入口 */
.quick-entry {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #FFFFFF;
  display: flex;
  padding: 20rpx 0;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  box-shadow: 0 -4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.entry-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  font-size: 22rpx;
  color: #666666;
}

.entry-icon {
  width: 48rpx;
  height: 48rpx;
  margin-bottom: 8rpx;
}
