/* 签名确认 */
.page {
  background-color: #F5F5F5;
  min-height: 100vh;
  padding-bottom: 140rpx;
}

.section-card {
  background: #FFFFFF;
  margin: 20rpx 32rpx;
  border-radius: 16rpx;
  padding: 28rpx 32rpx;
  box-shadow: 0 4rpx 16rpx rgba(27,42,74,0.08);
}

.card-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1B2A4A;
  margin-bottom: 20rpx;
}

.summary-grid {
  display: flex;
  flex-wrap: wrap;
}

.summary-item {
  width: 50%;
  display: flex;
  justify-content: space-between;
  padding: 12rpx 0;
  border-bottom: 1rpx solid #F5F5F5;
}

.summary-label {
  font-size: 26rpx;
  color: #999999;
}

.summary-value {
  font-size: 26rpx;
  color: #333333;
  font-weight: 500;
}

.fabric-row {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.fabric-item {
  display: flex;
  justify-content: space-between;
}

.fabric-label {
  font-size: 26rpx;
  color: #999999;
}

.fabric-value {
  font-size: 26rpx;
  color: #333333;
  font-weight: 500;
}

/* 签名区域 */
.canvas-wrap {
  border: 2rpx dashed #D0D0D0;
  border-radius: 12rpx;
  overflow: hidden;
}

.sign-canvas {
  width: 100%;
  height: 400rpx;
  background: #FAFAFA;
}

.sign-tips {
  text-align: center;
  font-size: 24rpx;
  color: #C9A96E;
  margin-top: 12rpx;
}

.sign-btns {
  margin-top: 16rpx;
  display: flex;
  justify-content: flex-end;
}

.btn-clear {
  font-size: 26rpx;
  color: #999999;
  padding: 8rpx 24rpx;
  border: 2rpx solid #E0E0E0;
  border-radius: 8rpx;
}

/* 操作按钮 */
.action-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  padding: 20rpx 32rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background: #FFFFFF;
  box-shadow: 0 -4rpx 16rpx rgba(0,0,0,0.06);
  gap: 24rpx;
}

.btn {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  font-size: 32rpx;
  font-weight: 600;
  border-radius: 16rpx;
}

.btn-back {
  background: #F5F5F5;
  color: #666666;
}

.btn-submit {
  background: #1B2A4A;
  color: #FFFFFF;
}

.btn-submit.disabled {
  background: #CCCCCC;
  color: #FFFFFF;
}
