/* 订单分派 */
.page {
  background-color: #F5F5F5;
  min-height: 100vh;
}

.tabs {
  display: flex;
  background: #FFFFFF;
  padding: 0 32rpx;
  border-bottom: 2rpx solid #F0F0F0;
}

.tab {
  flex: 1;
  text-align: center;
  padding: 24rpx 0;
  font-size: 28rpx;
  color: #999999;
  position: relative;
}

.tab.active {
  color: #1B2A4A;
  font-weight: 600;
}

.tab.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 48rpx;
  height: 6rpx;
  background: #C9A96E;
  border-radius: 3rpx;
}

.order-list {
  padding: 20rpx 32rpx;
}

.order-card {
  background: #FFFFFF;
  border-radius: 16rpx;
  padding: 28rpx 32rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 4rpx 16rpx rgba(27,42,74,0.08);
}

.order-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.order-no {
  font-size: 26rpx;
  color: #999999;
}

.order-info {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  margin-bottom: 20rpx;
}

.order-customer, .order-time, .order-style, .order-tailor {
  font-size: 28rpx;
  color: #333333;
}

.order-actions {
  display: flex;
  gap: 20rpx;
  border-top: 1rpx solid #F0F0F0;
  padding-top: 20rpx;
}

.action-btn {
  flex: 1;
  height: 72rpx;
  line-height: 72rpx;
  text-align: center;
  font-size: 28rpx;
  font-weight: 500;
  border-radius: 12rpx;
}

.action-btn.self {
  background: #F5F5F5;
  color: #666666;
}

.action-btn.assign {
  background: #1B2A4A;
  color: #FFFFFF;
}

/* 弹窗 */
.modal-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.5);
  display: flex;
  align-items: flex-end;
  z-index: 999;
}

.modal-content {
  width: 100%;
  background: #FFFFFF;
  border-radius: 24rpx 24rpx 0 0;
  padding: 32rpx;
  padding-bottom: calc(32rpx + env(safe-area-inset-bottom));
  max-height: 70vh;
}

.modal-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1B2A4A;
  text-align: center;
  margin-bottom: 24rpx;
}

.tailor-list {
  max-height: 50vh;
  overflow-y: auto;
}

.tailor-item {
  display: flex;
  align-items: center;
  padding: 20rpx;
  border: 2rpx solid #E0E0E0;
  border-radius: 12rpx;
  margin-bottom: 16rpx;
}

.tailor-item.active {
  border-color: #C9A96E;
  background: #FFF8F0;
}

.tailor-avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: #F0F0F0;
}

.tailor-info {
  flex: 1;
  margin-left: 20rpx;
}

.tailor-name {
  font-size: 28rpx;
  color: #333333;
  font-weight: 500;
  display: block;
}

.tailor-meta {
  margin-top: 4rpx;
}

.tailor-rating, .tailor-orders {
  font-size: 24rpx;
  color: #999999;
  margin-right: 16rpx;
}

.tailor-check {
  color: #C9A96E;
  font-size: 36rpx;
  font-weight: 700;
}

.modal-btns {
  display: flex;
  gap: 24rpx;
  margin-top: 24rpx;
}

.modal-btn {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  text-align: center;
  border-radius: 12rpx;
  font-size: 30rpx;
}

.modal-btn.cancel {
  background: #F5F5F5;
  color: #999999;
}

.modal-btn.confirm {
  background: #1B2A4A;
  color: #FFFFFF;
}
