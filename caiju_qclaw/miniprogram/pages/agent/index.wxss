/* 代理工作台 */
.page {
  background-color: #F5F5F5;
  min-height: 100vh;
  padding-bottom: 40rpx;
}

.header {
  background: linear-gradient(135deg, #1B2A4A 0%, #2D4270 100%);
  padding: 40rpx 32rpx 48rpx;
  color: #FFFFFF;
}

.header-top {
  margin-bottom: 32rpx;
}

.school-name {
  font-size: 34rpx;
  font-weight: 600;
}

.agent-level {
  margin-top: 8rpx;
}

.level-badge {
  font-size: 22rpx;
  color: #C9A96E;
  background: rgba(201,169,110,0.2);
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
}

.core-stats {
  display: flex;
  align-items: center;
  background: rgba(255,255,255,0.1);
  border-radius: 16rpx;
  padding: 28rpx 0;
}

.stat-item {
  flex: 1;
  text-align: center;
}

.stat-value {
  font-size: 40rpx;
  font-weight: 700;
  color: #FFFFFF;
  display: block;
}

.stat-label {
  font-size: 22rpx;
  color: rgba(255,255,255,0.6);
  margin-top: 4rpx;
  display: block;
}

.stat-divider {
  width: 1rpx;
  height: 60rpx;
  background: rgba(255,255,255,0.2);
}

/* 待处理 */
.pending-card {
  margin: -24rpx 32rpx 20rpx;
  background: #FFFFFF;
  border-radius: 16rpx;
  padding: 28rpx 32rpx;
  box-shadow: 0 4rpx 16rpx rgba(27,42,74,0.08);
}

.pending-title {
  font-size: 28rpx;
  color: #1B2A4A;
  font-weight: 600;
  margin-bottom: 16rpx;
}

.pending-row {
  display: flex;
  gap: 24rpx;
}

.pending-item {
  flex: 1;
  display: flex;
  align-items: center;
  background: #FFF8F0;
  border-radius: 12rpx;
  padding: 20rpx;
}

.pending-num {
  font-size: 40rpx;
  font-weight: 700;
  color: #C9A96E;
  margin-right: 12rpx;
}

.pending-text {
  font-size: 26rpx;
  color: #666666;
}

/* 订单列表 */
.section {
  margin: 20rpx 32rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1B2A4A;
}

.section-more {
  font-size: 26rpx;
  color: #C9A96E;
}

.order-item {
  margin-bottom: 16rpx;
}

/* 快捷入口 */
.quick-grid {
  display: flex;
  margin: 20rpx 32rpx;
  gap: 16rpx;
}

.quick-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  background: #FFFFFF;
  border-radius: 16rpx;
  padding: 28rpx 0;
  box-shadow: 0 4rpx 16rpx rgba(27,42,74,0.08);
}

.quick-icon {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 12rpx;
}

.icon-text {
  font-size: 32rpx;
  font-weight: 700;
}

.quick-label {
  font-size: 24rpx;
  color: #666666;
}
