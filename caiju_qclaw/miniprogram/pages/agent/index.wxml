<!-- 代理工作台 -->
<view class="page">
  <!-- 顶部 -->
  <view class="header">
    <view class="header-top">
      <view>
        <text class="school-name">{{schoolName}}</text>
        <view class="agent-level">
          <text class="level-badge">{{levelName}}</text>
        </view>
      </view>
    </view>
    <!-- 核心数据 -->
    <view class="core-stats">
      <view class="stat-item">
        <text class="stat-value">{{monthOrders}}</text>
        <text class="stat-label">本月订单</text>
      </view>
      <view class="stat-divider"></view>
      <view class="stat-item">
        <text class="stat-value">¥{{monthCommission}}</text>
        <text class="stat-label">本月佣金</text>
      </view>
      <view class="stat-divider"></view>
      <view class="stat-item">
        <text class="stat-value">{{teamCount}}</text>
        <text class="stat-label">团队人数</text>
      </view>
    </view>
  </view>

  <!-- 待处理事项 -->
  <view class="pending-card" wx:if="{{pendingAssign > 0 || pendingAfterSale > 0}}">
    <view class="pending-title">待处理事项</view>
    <view class="pending-row">
      <view class="pending-item" bindtap="goToAssign" wx:if="{{pendingAssign > 0}}">
        <text class="pending-num">{{pendingAssign}}</text>
        <text class="pending-text">待分配订单</text>
      </view>
      <view class="pending-item" bindtap="goToAfterSale" wx:if="{{pendingAfterSale > 0}}">
        <text class="pending-num">{{pendingAfterSale}}</text>
        <text class="pending-text">待跟进售后</text>
      </view>
    </view>
  </view>

  <!-- 今日订单 -->
  <view class="section">
    <view class="section-header">
      <text class="section-title">今日订单</text>
      <text class="section-more" bindtap="goToAssign">查看全部 ›</text>
    </view>
    <view wx:if="{{todayOrders.length === 0}}">
      <empty-state message="今日暂无订单" />
    </view>
    <view class="order-item" wx:for="{{todayOrders}}" wx:key="_id">
      <order-card order="{{item}}" />
    </view>
  </view>

  <!-- 快捷入口 -->
  <view class="quick-grid">
    <view class="quick-item" bindtap="goToPromo">
      <view class="quick-icon" style="background:#FFF8F0;">
        <text class="icon-text" style="color:#C9A96E;">码</text>
      </view>
      <text class="quick-label">推广码</text>
    </view>
    <view class="quick-item" bindtap="goToPlaceOrder">
      <view class="quick-icon" style="background:#F0F4FF;">
        <text class="icon-text" style="color:#1B2A4A;">单</text>
      </view>
      <text class="quick-label">代客下单</text>
    </view>
    <view class="quick-item" bindtap="goToTeam">
      <view class="quick-icon" style="background:#F0FFF4;">
        <text class="icon-text" style="color:#52C41A;">队</text>
      </view>
      <text class="quick-label">团队管理</text>
    </view>
    <view class="quick-item" bindtap="goToIncome">
      <view class="quick-icon" style="background:#FFF0F0;">
        <text class="icon-text" style="color:#FF4D4F;">佣</text>
      </view>
      <text class="quick-label">收入中心</text>
    </view>
  </view>
</view>
