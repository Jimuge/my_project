/* 订单列表页样式 */
.tabs { display: flex; background: #FFF; margin-bottom: 24rpx; position: sticky; top: 0; z-index: 10; }
.tab-item { flex: 1; text-align: center; padding: 24rpx 0; font-size: 28rpx; color: #999; position: relative; }
.tab-item.active { color: #1B2A4A; font-weight: 500; }
.tab-item.active::after { content: ''; position: absolute; bottom: 0; left: 50%; transform: translateX(-50%); width: 40rpx; height: 4rpx; background: #1B2A4A; border-radius: 2rpx; }
.order-list { padding: 0 24rpx; }
