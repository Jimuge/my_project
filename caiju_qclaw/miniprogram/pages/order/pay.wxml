<!-- 支付页 -->
<view class="page" wx:if="{{order}}">
  <view class="card">
    <view class="card-title">订单信息</view>
    <view class="info-row">
      <text>订单编号</text>
      <text>{{order.orderNo}}</text>
    </view>
    <view class="info-row">
      <text>支付金额</text>
      <text class="price">¥{{order.totalPrice / 100}}</text>
    </view>
  </view>

  <view class="card">
    <view class="card-title">支付方式</view>
    <picker mode="selector" range="{{payMethods}}" bindchange="onPayMethodChange">
      <view class="picker-value">{{payMethods[payMethodIndex]}} ></view>
    </picker>
  </view>

  <view class="bottom-bar safe-area-bottom">
    <view class="pay-info">
      <text>支付金额：</text>
      <text class="pay-price">¥{{order.totalPrice / 100}}</text>
    </view>
    <button class="btn btn-primary pay-btn" bindtap="onConfirmPay">立即支付</button>
  </view>
</view>
