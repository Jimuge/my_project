<!-- 下单页 -->
<view class="page">
  <!-- 款式信息 -->
  <view class="card" wx:if="{{style}}">
    <view class="card-title">{{style.name}}</view>
    <view class="style-price">起售价：¥{{style.minPrice / 100}}</view>
  </view>

  <!-- 布料选择 -->
  <view class="card">
    <view class="card-title">选择布料</view>
    <picker mode="selector" range="{{style.fabrics}}" range-key="name" bindchange="onFabricChange">
      <view class="picker-value">{{selectedFabric.name}} ({{selectedFabric.priceAdd > 0 ? '+' + selectedFabric.priceAdd / 100 : '无加价'}})</view>
    </picker>
  </view>

  <!-- 订单总价 -->
  <view class="card">
    <view class="total-price">
      <text>订单总价：</text>
      <text class="price-value">¥{{totalPrice / 100}}</text>
    </view>
  </view>

  <!-- 提交按钮 -->
  <view class="bottom-bar safe-area-bottom">
    <button class="btn btn-primary btn-block" bindtap="onSubmit">提交订单</button>
  </view>
</view>
<loading loading="{{loading}}"></loading>
