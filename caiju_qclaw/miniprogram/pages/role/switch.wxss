/* 身份切换页样式 */
.role-switch-page {
  min-height: 100vh;
  background-color: #F5F5F5;
  padding: 48rpx 24rpx;
}

.page-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #333333;
  text-align: center;
  margin-bottom: 48rpx;
}

.role-list {
  margin-bottom: 24rpx;
}

.role-item {
  display: flex;
  align-items: center;
  background-color: #FFFFFF;
  border-radius: 16rpx;
  padding: 32rpx 24rpx;
  margin-bottom: 24rpx;
  border: 2rpx solid #E5E5E5;
  transition: all 0.3s ease;
}

.role-item.active {
  border-color: #C9A96E;
  background-color: rgba(201, 169, 110, 0.05);
}

.role-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background-color: #F5F5F5;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  margin-right: 24rpx;
}

.role-info {
  flex: 1;
}

.role-name {
  font-size: 32rpx;
  color: #333333;
  font-weight: 500;
}

.role-desc {
  font-size: 24rpx;
  color: #999999;
  margin-top: 8rpx;
}

.role-check {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background-color: #C9A96E;
  color: #FFFFFF;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
}
