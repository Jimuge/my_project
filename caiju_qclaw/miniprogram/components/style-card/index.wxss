/* 款式卡片组件样式 */
.style-card {
  background-color: #FFFFFF;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

/* 图片区域 */
.style-image-wrapper {
  position: relative;
  width: 100%;
  height: 320rpx;
}

.style-image {
  width: 100%;
  height: 100%;
  background-color: #F5F5F5;
}

.style-tag {
  position: absolute;
  top: 16rpx;
  left: 16rpx;
  background-color: #C9A96E;
  color: #FFFFFF;
  font-size: 22rpx;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
}

/* 内容区域 */
.style-content {
  padding: 20rpx;
}

.style-name {
  font-size: 30rpx;
  color: #333333;
  font-weight: 500;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.style-desc {
  font-size: 24rpx;
  color: #999999;
  margin-top: 8rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.style-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 16rpx;
}

.style-sales {
  font-size: 24rpx;
  color: #CCCCCC;
}
