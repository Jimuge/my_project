/* 支付页样式 */
.info-row { display: flex; justify-content: space-between; padding: 16rpx 0; font-size: 28rpx; }
.picker-value { padding: 20rpx 0; font-size: 28rpx; }
.price { color: #F5222D; font-weight: 600; }
.bottom-bar { position: fixed; left: 0; right: 0; bottom: 0; background: #FFF; padding: 20rpx 24rpx; display: flex; justify-content: space-between; align-items: center; box-shadow: 0 -2rpx 12rpx rgba(0,0,0,0.06); }
.pay-info { font-size: 28rpx; }
.pay-price { color: #F5222D; font-weight: 600; font-size: 36rpx; }
.pay-btn { margin: 0; padding: 16rpx 48rpx; }
