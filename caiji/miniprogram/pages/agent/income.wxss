/* 佣金结算 */
.page {
  background-color: #F5F5F5;
  min-height: 100vh;
  padding-bottom: 40rpx;
}

.commission-header {
  background: linear-gradient(135deg, #1B2A4A 0%, #2D4270 100%);
  padding: 40rpx 32rpx 48rpx;
  color: #FFFFFF;
}

.comm-label {
  font-size: 26rpx;
  color: rgba(255,255,255,0.7);
}

.comm-amount {
  font-size: 64rpx;
  font-weight: 700;
  color: #C9A96E;
  display: block;
  margin: 8rpx 0 28rpx;
}

.comm-row {
  display: flex;
  gap: 32rpx;
}

.comm-item {
  flex: 1;
}

.comm-value {
  font-size: 32rpx;
  font-weight: 600;
  display: block;
}

.comm-desc {
  font-size: 24rpx;
  color: rgba(255,255,255,0.6);
  margin-top: 4rpx;
  display: block;
}

/* 提现表单 */
.section-card {
  background: #FFFFFF;
  margin: 20rpx 32rpx;
  border-radius: 16rpx;
  padding: 28rpx 32rpx;
  box-shadow: 0 4rpx 16rpx rgba(27,42,74,0.08);
}

.card-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1B2A4A;
  margin-bottom: 20rpx;
}

.form-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #F0F0F0;
}

.form-label {
  font-size: 28rpx;
  color: #666666;
}

.amount-input-wrap {
  display: flex;
  align-items: center;
  flex: 1;
  justify-content: flex-end;
}

.amount-prefix {
  font-size: 32rpx;
  color: #333333;
  font-weight: 600;
  margin-right: 8rpx;
}

.amount-input {
  font-size: 32rpx;
  color: #333333;
  text-align: right;
  width: 200rpx;
}

.form-value {
  font-size: 28rpx;
  color: #999999;
}

.withdraw-btn {
  margin-top: 28rpx;
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  background: #1B2A4A;
  color: #FFFFFF;
  font-size: 32rpx;
  font-weight: 600;
  border-radius: 16rpx;
}

/* 明细 */
.section {
  margin: 20rpx 32rpx;
}

.section-header {
  margin-bottom: 16rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1B2A4A;
  margin-bottom: 16rpx;
}

.detail-list {
  background: #FFFFFF;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 16rpx rgba(27,42,74,0.08);
}

.detail-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 32rpx;
  border-bottom: 1rpx solid #F5F5F5;
}

.detail-item:last-child {
  border-bottom: none;
}

.detail-left {
  flex: 1;
}

.detail-top {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.detail-desc {
  font-size: 28rpx;
  color: #333333;
}

.detail-tag {
  font-size: 20rpx;
  padding: 2rpx 12rpx;
  border-radius: 6rpx;
}

.tag-direct {
  color: #1B2A4A;
  background: #F0F4FF;
}

.tag-indirect {
  color: #52C41A;
  background: #F0FFF4;
}

.tag_measure {
  color: #C9A96E;
  background: #FFF8F0;
}

.detail-time {
  font-size: 24rpx;
  color: #999999;
  margin-top: 6rpx;
  display: block;
}

.detail-amount {
  font-size: 32rpx;
  color: #C9A96E;
  font-weight: 600;
}

/* 规则 */
.rules-card {
  background: #FFFFFF;
  border-radius: 16rpx;
  padding: 24rpx 32rpx;
  box-shadow: 0 4rpx 16rpx rgba(27,42,74,0.08);
}

.rule-item {
  display: flex;
  font-size: 26rpx;
  color: #666666;
  line-height: 1.8;
}

.rule-dot {
  color: #C9A96E;
  margin-right: 12rpx;
}
