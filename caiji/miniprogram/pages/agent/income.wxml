<!-- 佣金结算 -->
<view class="page">
  <!-- 佣金概览 -->
  <view class="commission-header">
    <view class="comm-main">
      <text class="comm-label">可提现余额</text>
      <text class="comm-amount">¥{{availableBalance}}</text>
    </view>
    <view class="comm-row">
      <view class="comm-item">
        <text class="comm-value">¥{{monthTotal}}</text>
        <text class="comm-desc">本月累计</text>
      </view>
      <view class="comm-item">
        <text class="comm-value">¥{{pendingSettle}}</text>
        <text class="comm-desc">待结算</text>
      </view>
    </view>
  </view>

  <!-- 提现 -->
  <view class="section-card">
    <view class="card-title">申请提现</view>
    <view class="withdraw-form">
      <view class="form-row">
        <text class="form-label">提现金额</text>
        <view class="amount-input-wrap">
          <text class="amount-prefix">¥</text>
          <input class="amount-input" type="digit" placeholder="请输入金额" value="{{withdrawAmount}}" bindinput="onAmountInput" />
        </view>
      </view>
      <view class="form-row">
        <text class="form-label">银行卡</text>
        <text class="form-value">{{bankCard || '请选择银行卡'}} ›</text>
      </view>
      <view class="withdraw-btn" bindtap="onWithdraw">申请提现</view>
    </view>
  </view>

  <!-- 佣金明细 -->
  <view class="section">
    <view class="section-header">
      <text class="section-title">佣金明细</text>
    </view>
    <view class="detail-list">
      <view class="detail-item" wx:for="{{commissionList}}" wx:key="_id">
        <view class="detail-left">
          <view class="detail-top">
            <text class="detail-desc">{{item.desc}}</text>
            <text class="detail-tag tag-{{item.type}}">{{item.typeLabel}}</text>
          </view>
          <text class="detail-time">{{item.time}}</text>
        </view>
        <text class="detail-amount">+¥{{item.amount}}</text>
      </view>
    </view>
    <empty-state wx:if="{{commissionList.length === 0}}" message="暂无佣金记录" />
  </view>

  <!-- 结算规则 -->
  <view class="section">
    <view class="section-title">结算规则</view>
    <view class="rules-card">
      <view class="rule-item"><text class="rule-dot">•</text><text>直推佣金：客户下单金额的 8%</text></view>
      <view class="rule-item"><text class="rule-dot">•</text><text>间接佣金：团队成员下单金额的 3%</text></view>
      <view class="rule-item"><text class="rule-dot">•</text><text>量体佣金：亲自量体完成订单额外 5%</text></view>
      <view class="rule-item"><text class="rule-dot">•</text><text>提现最低 50 元，1-3 个工作日到账</text></view>
    </view>
  </view>
</view>
