/* 推广码 */
.page {
  background-color: #F5F5F5;
  min-height: 100vh;
}

.qrcode-card {
  background: #FFFFFF;
  margin: 20rpx 32rpx;
  border-radius: 16rpx;
  padding: 40rpx 32rpx;
  text-align: center;
  box-shadow: 0 4rpx 16rpx rgba(27,42,74,0.08);
}

.qrcode-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1B2A4A;
  margin-bottom: 32rpx;
}

.qrcode-img {
  width: 360rpx;
  height: 360rpx;
  background: #F0F0F0;
  border-radius: 12rpx;
}

.qrcode-actions {
  display: flex;
  gap: 24rpx;
  margin-top: 32rpx;
  justify-content: center;
}

.qr-btn {
  height: 72rpx;
  line-height: 72rpx;
  padding: 0 40rpx;
  font-size: 28rpx;
  border-radius: 12rpx;
  background: #1B2A4A;
  color: #FFFFFF;
}

.share-btn {
  background: #C9A96E;
}

.share-button {
  background: transparent;
  color: #FFFFFF;
  font-size: 28rpx;
  padding: 0;
  margin: 0;
  line-height: 72rpx;
}

.stats-card {
  background: #FFFFFF;
  margin: 20rpx 32rpx;
  border-radius: 16rpx;
  padding: 28rpx 32rpx;
  box-shadow: 0 4rpx 16rpx rgba(27,42,74,0.08);
}

.stats-row {
  display: flex;
}

.stats-item {
  flex: 1;
  text-align: center;
}

.stats-value {
  font-size: 40rpx;
  font-weight: 700;
  color: #1B2A4A;
  display: block;
}

.stats-label {
  font-size: 24rpx;
  color: #999999;
  margin-top: 4rpx;
  display: block;
}

.section {
  margin: 20rpx 32rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1B2A4A;
  margin-bottom: 16rpx;
}

.promo-list {
  background: #FFFFFF;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 16rpx rgba(27,42,74,0.08);
}

.promo-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 32rpx;
  border-bottom: 1rpx solid #F5F5F5;
}

.promo-item:last-child {
  border-bottom: none;
}

.promo-left {
  display: flex;
  flex-direction: column;
}

.promo-channel {
  font-size: 28rpx;
  color: #333333;
}

.promo-date {
  font-size: 24rpx;
  color: #999999;
  margin-top: 4rpx;
}

.promo-right {
  display: flex;
  gap: 24rpx;
}

.promo-scans, .promo-orders {
  font-size: 24rpx;
  color: #666666;
}
