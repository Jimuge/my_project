/* 登录授权页样式 */
.auth-page {
  min-height: 100vh;
  background: linear-gradient(180deg, #1B2A4A 0%, #2A3F5F 50%, #F5F5F5 100%);
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 160rpx;
}

/* Logo 区域 */
.logo-section {
  text-align: center;
  margin-bottom: 160rpx;
}

.logo {
  width: 160rpx;
  height: 160rpx;
  background-color: rgba(255, 255, 255, 0.1);
  border-radius: 32rpx;
}

.app-name {
  font-size: 48rpx;
  font-weight: 600;
  color: #FFFFFF;
  margin-top: 32rpx;
}

.app-slogan {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.7);
  margin-top: 16rpx;
}

/* 授权区域 */
.auth-section {
  width: 100%;
  padding: 0 48rpx;
}

.auth-btn {
  width: 100%;
  height: 96rpx;
  border-radius: 48rpx;
  font-size: 32rpx;
  font-weight: 500;
  margin-bottom: 24rpx;
}

.auth-btn.primary {
  background-color: #C9A96E;
  color: #FFFFFF;
  border: none;
}

.auth-btn.primary:active {
  opacity: 0.8;
}

.auth-btn.secondary {
  background-color: rgba(255, 255, 255, 0.1);
  color: #FFFFFF;
  border: 1rpx solid rgba(255, 255, 255, 0.3);
}

.auth-btn.secondary:active {
  background-color: rgba(255, 255, 255, 0.2);
}

/* 用户协议 */
.agreement {
  position: fixed;
  bottom: env(safe-area-inset-bottom);
  padding-bottom: 32rpx;
  font-size: 24rpx;
  color: #999999;
}

.agreement .link {
  color: #C9A96E;
}
