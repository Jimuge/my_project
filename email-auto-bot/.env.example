# ============================================================
# 智能邮件自动回复系统 — 环境变量配置模板
# ============================================================
# 使用方法：
#   复制此文件为 .env，然后修改其中的配置项
# ============================================================

# ============================================================
# 邮箱 POP3 配置（收邮件用）
# ============================================================
# POP3 服务器地址
#   163邮箱: pop.163.com
#   QQ邮箱:  pop.qq.com
#   Gmail:   pop.gmail.com
POP3_SERVER=pop.163.com

# POP3 端口（995 是 SSL 端口）
POP3_PORT=995

# 邮箱登录信息
POP3_USER=你的邮箱地址@163.com
POP3_PASSWORD=你的邮箱授权码

# ============================================================
# 邮箱 SMTP 配置（发邮件用）
# ============================================================
SMTP_SERVER=smtp.163.com
SMTP_PORT=465
SMTP_USER=你的邮箱地址@163.com
SMTP_PASSWORD=你的邮箱授权码

# ============================================================
# DeepSeek AI 配置（用于生成智能回复）
# ============================================================
DEEPSEEK_API_KEY=你的DeepSeek API密钥
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# ============================================================
# 自动回复规则配置
# ============================================================
# 回复模式：whitelist（仅回复白名单）或 all（回复所有邮件）
REPLY_MODE=whitelist

# 白名单（多个邮箱用逗号分隔）
# 只有这些地址发来的邮件才会自动回复
REPLY_WHITELIST=friend@example.com, colleague@company.com

# 检查新邮件的间隔时间（秒）
# 在 watch 模式下，每隔多少秒检查一次收件箱
CHECK_INTERVAL=60

# AI 回复的"人设"设定
# 告诉 DeepSeek 以什么身份和风格回复邮件
# 例如：友好的智能客服助手、一本正经胡说八道的搞笑人物、专业的技术支持等
AI_PERSONA=你是一个友好的智能客服助手
